{
  "name": "vscode-nord-proxy",
  "displayName": "Nord Proxy",
  "description": "Restart VS Code through NordVPN's authenticated proxy servers.",
  "icon": "assets/icon.png",
  "version": "0.0.3",
  "publisher": "tomlaws",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomlaws/vscode-nord-proxy.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "nordvpn",
    "proxy",
    "privacy",
    "vpn"
  ],
  "license": "MIT",
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nord-proxy.connect",
        "title": "Restart VS Code with Proxy",
        "category": "Nord Proxy"
      },
      {
        "command": "nord-proxy.disconnect",
        "title": "Restart VS Code without Proxy",
        "category": "Nord Proxy"
      },
      {
        "command": "nord-proxy.setCredentials",
        "title": "Set NordVPN Service Credentials",
        "category": "Nord Proxy"
      },
      {
        "command": "nord-proxy.selectLocation",
        "title": "Change Proxy Location",
        "category": "Nord Proxy"
      },
      {
        "command": "nord-proxy.testConnection",
        "title": "Verify Proxy and Show Exit IP",
        "category": "Nord Proxy"
      },
      {
        "command": "nord-proxy.showStatus",
        "title": "Show Status",
        "category": "Nord Proxy"
      }
    ],
    "configuration": {
      "title": "Nord Proxy",
      "properties": {
        "nordProxy.localPort": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "Loopback port used by the proxy bridge. Use 0 to select a free port automatically. If a configured port is occupied, the extension falls back to a free port."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "npm run compile",
    "package:vsix": "npx --yes @vscode/vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.90.0",
    "eslint": "^10.7.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.64.0"
  }
}